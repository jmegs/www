---
import { Icon } from "astro-icon/components"
---

<button
	id="theme-toggle"
	aria-label="Toggle theme"
	class="hover:rotate-2 hover:scale-[.98] hover:text-gray-11"
	title="Change theme. Alt-click to reset."
>
	<Icon
		size={24}
		name="ph:sun-horizon-light"
		class="h-6 w-6 rotate-0 scale-100 transition-all dark:-rotate-12 dark:scale-0"
	/>
	<Icon
		size={24}
		name="ph:moon-stars-light"
		class="h-6 w-6 rotate-12 scale-0 transition-all dark:rotate-0 dark:scale-100"
	/>
</button>

<script>
	const toggleButton: HTMLButtonElement | null = document.querySelector("#theme-toggle")
	const doc = document.documentElement
	const mq = "(prefers-color-scheme: dark)"

	const handleToggleClick = (event: MouseEvent) => {
		const isDark = doc.classList.contains("dark")
		const nextTheme = isDark ? "light" : "dark"

		if (event.altKey) {
			const systemPrefersDark = window.matchMedia(mq).matches
			localStorage.removeItem("theme")
			doc.classList.toggle("dark", systemPrefersDark)
		} else {
			doc.classList.toggle("dark")
			localStorage.setItem("theme", nextTheme)
		}
	}

	toggleButton?.addEventListener("click", handleToggleClick)
</script>

<style scoped>
	button {
		display: grid;
		grid-template: 1 / 1 / 1 / 1;
	}

	[data-icon] {
		grid-area: 1 / 1;
	}
</style>
